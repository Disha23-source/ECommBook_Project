@using EComm_Project_Utility

@inject IHttpContextAccessor httpContextAccessor
@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EComm_Project</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EComm_Project.styles.css" asp-append-version="true" />

    @*CSS ref*@
    <link rel="stylesheet" href="https://cdn.datatables.net/1.10.16/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/jquery-ui.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/sweetalert/1.1.3/sweetalert.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />


</head>
<body>
<header>
  <nav class="navbar navbar-expand-sm navbar-toggleable-sm mb-3"
       style="background:#0f172a; border-bottom:1px solid rgba(255,255,255,0.08); padding:0 24px; min-height:64px;">
    <div class="container-fluid d-flex align-items-center justify-content-between flex-wrap gap-2">

      <!-- LEFT: Logo + Links -->
      <div class="d-flex align-items-center gap-3">
        <a class="d-flex align-items-center gap-2 text-white fw-semibold text-decoration-none"
           asp-area="Customer" asp-controller="Home" asp-action="Index" style="font-size:17px;">
          <div style="width:30px;height:30px;background:linear-gradient(135deg,#6366f1,#8b5cf6);border-radius:8px;display:grid;place-items:center;">
            <i class="fa fa-book" style="color:white;font-size:13px;"></i>
          </div>
            &nbsp; BookShelf
        </a>

        <ul class="navbar-nav d-flex flex-row gap-1 mb-0">
          <li class="nav-item">
            <a class="nav-link nav-pill" asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a>
          </li>

          <!-- CATEGORY DROPDOWN -->
          <li class="nav-item dropdown">
            <a class="nav-link nav-pill dropdown-toggle" href="#"
               id="categoryDropdownToggle" role="button"
               data-bs-toggle="dropdown" aria-expanded="false">
              Categories
            </a>
            <ul class="dropdown-menu dropdown-dark-custom" id="categoryDropdownMenu"
                aria-labelledby="categoryDropdownToggle">
              <li><span class="dropdown-item text-muted" style="font-size:12px;">Loading...</span></li>
            </ul>
          </li>

          @* <li class="nav-item">
            <a class="nav-link nav-pill" asp-area="Customer" asp-controller="Home" asp-action="Privacy">Privacy</a>
          </li> *@

          @if (User.IsInRole(SD.Role_Employee) || User.IsInRole(SD.Role_Admin))
          {
            <li class="nav-item dropdown">
              <a class="nav-link nav-pill dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button">
                Content Management
              </a>
              <ul class="dropdown-menu dropdown-dark-custom">
                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Category" asp-action="Index">Category</a></li>
                <li><a class="dropdown-item" asp-area="Admin" asp-controller="CoverType" asp-action="Index">Cover Type</a></li>
                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Product" asp-action="Index">Products</a></li>
              </ul>
            </li>
          }
          @if (User.IsInRole(SD.Role_Admin))
          {
            <li class="nav-item dropdown">
              <a class="nav-link nav-pill dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button">
                Company/Users
              </a>
              <ul class="dropdown-menu dropdown-dark-custom">
                <li><a class="dropdown-item" asp-area="Admin" asp-controller="User" asp-action="Index">User</a></li>
                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Company" asp-action="Index">Company</a></li>
              </ul>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link nav-pill dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button">
                Order Management
              </a>
              <ul class="dropdown-menu dropdown-dark-custom">
                <li><a class="dropdown-item" asp-area="Admin" asp-controller="OrderManagement" asp-action="AllOrders">All Orders</a></li>
                <li><a class="dropdown-item" asp-area="Admin" asp-controller="OrderManagement" asp-action="DatewiseOrders">Datewise Orders</a></li>
                <li><a class="dropdown-item" asp-area="Admin" asp-controller="OrderManagement" asp-action="MonthlyOrders">Monthly Orders</a></li>
              </ul>
            </li>
          }
        </ul>
      </div>

      <!-- CENTER: Search -->
      <div style="position:relative; width:260px;" id="searchWrapper">
        <div style="display:flex;align-items:center;gap:8px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:9px;padding:7px 14px;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
               stroke="rgba(255,255,255,0.4)" stroke-width="2" stroke-linecap="round">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input type="text" id="searchInput"
                 placeholder="Search title or author..."
                 autocomplete="off"
                 style="background:none;border:none;outline:none;color:#fff;font-size:13px;width:100%;" />
        </div>
        <!-- Suggestions Box -->
        <div id="searchDropdown"
             style="display:none;position:absolute;top:calc(100% + 6px);left:0;right:0;
                    background:#1e293b;border:1px solid rgba(255,255,255,0.1);
                    border-radius:10px;overflow:hidden;z-index:9999;
                    box-shadow:0 8px 24px rgba(0,0,0,0.4);">
          <div id="searchResults"></div>
        </div>
      </div>

      <!-- RIGHT: Login/Register + Cart -->
      <div class="d-flex align-items-center gap-2">
        <partial name="_LoginPartial" />
        @{
          var cartCount = httpContextAccessor.HttpContext.Session.GetInt32(SD.Ss_CartSessionCount) ?? 0;
        }
        <a asp-area="Customer" asp-controller="Cart" asp-action="Index"
           style="position:relative;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);
                  border-radius:8px;padding:7px 10px;color:rgba(255,255,255,0.7);display:inline-block;text-decoration:none;">
          <i class="fa fa-shopping-cart"></i>
          <span style="position:absolute;top:-4px;right:-4px;width:16px;height:16px;
                       background:#6366f1;color:#fff;font-size:9px;font-weight:700;
                       border-radius:50%;display:grid;place-items:center;border:2px solid #0f172a;">
            @cartCount
          </span>
        </a>
      </div>

    </div>
  </nav>
</header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-primary">
        <div class="container">
            &copy; 2026 - Book Shopping <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @*JS REF*@
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.12.1/jquery-ui.min.js"></script>
    <script src="https://cdn.datatables.net/1.10.16/js/jquery.dataTables.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>
    <script src="https://kit.fontawesome.com/e19c476714.js"></script>
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
