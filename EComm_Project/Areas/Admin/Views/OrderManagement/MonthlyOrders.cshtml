@model EComm_Project_Models.ViewModels.MonthlyOrderVM
@{
    ViewData["Title"] = "Monthly Orders";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4 px-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-0">
                <i class="bi bi-calendar3 me-2"></i>@Model.SelectedMonthName Orders
                <span class="text-muted fs-5">(@Model.SelectedYear)</span>
            </h2>
            <p class="text-muted mb-0">Showing orders for @Model.SelectedMonthName @Model.SelectedYear</p>
        </div>
        <div class="d-flex gap-4 p-2 m-2">
            <a asp-action="AllOrders" class="btn btn-primary">
                <i class="bi bi-list-ul me-1"></i> All Orders
            </a>
            <!-- Month Selector Dropdown -->
            <div class="dropdown">
                <button class="btn btn-primary dropdown-toggle px-4"
                        type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-calendar-event me-1"></i> @Model.SelectedMonthName
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow">
                    @foreach (var m in Model.Months)
                    {
                        <li>
                            <a class="dropdown-item @(m.Key == Model.SelectedMonth ? "active" : "")"
                               asp-area="Admin"
                               asp-controller="OrderManagement"
                               asp-action="MonthlyOrders"
                               asp-route-month="@m.Key">
                                @(m.Key == 0 ? "📋 " : "🗓️ ")@m.Value
                            </a>
                        </li>
                        @if (m.Key == 0)
                        {
                            <li><hr class="dropdown-divider"></li>
                        }
                    }
                </ul>
            </div>
        </div>
    </div>

    <!-- Stats Cards — same style as your DatewiseOrders -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3"
                 style="border-left:4px solid #0d6efd !important;">
                <div class="text-muted small">Total Orders</div>
                <div class="fs-3 fw-bold text-primary">@Model.TotalOrders</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3"
                 style="border-left:4px solid #198754 !important;">
                <div class="text-muted small">Approved Orders</div>
                <div class="fs-3 fw-bold text-success">
                    @Model.Orders.Count(o => o.OrderStatus == "Approved")
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3"
                 style="border-left:4px solid #ffc107 !important;">
                <div class="text-muted small">Pending Orders</div>
                <div class="fs-3 fw-bold text-warning">
                    @Model.Orders.Count(o => o.OrderStatus == "Pending")
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3"
                 style="border-left:4px solid #dc3545 !important;">
                <div class="text-muted small">Grand Total</div>
                <div class="fs-4 fw-bold text-danger">
                    ₹@Model.TotalRevenue.ToString("N2")
                </div>
            </div>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0">
                <i class="bi bi-table me-2"></i>
                Orders — @Model.SelectedMonthName @Model.SelectedYear
            </h6>
            <span class="badge bg-light text-primary">@Model.TotalOrders orders found</span>
        </div>
        <div class="card-body p-0">
            @if (Model.Orders.Count == 0)
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size:4rem;"></i>
                    <h4 class="text-muted mt-3">No Orders Found</h4>
                    <p class="text-muted">No orders found for @Model.SelectedMonthName @Model.SelectedYear</p>
                    <a asp-action="MonthlyOrders" asp-route-month="0"
                       asp-area="Admin" asp-controller="OrderManagement"
                       class="btn btn-outline-primary mt-2">
                        View All Months
                    </a>
                </div>
            }
            else
            {
                <table class="table table-bordered table-hover w-100 mb-0" id="monthlyTable">
                    <thead class="table-primary">
                        <tr>
                            <th>Order ID</th>
                            <th>Order Date</th>
                            <th>Customer Name</th>
                            <th>Email</th>
                            <th>Order Status</th>
                            <th>Payment Status</th>
                            <th class="text-end">Total Amount</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.Orders.OrderByDescending(o => o.OrderDate))
                        {
                            <tr>
                                <td>
                                    <span class="badge bg-secondary">#@order.Id</span>
                                </td>
                                <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td><strong>@order.Name</strong></td>
                                <td class="text-muted small">@order.ApplicationUser?.Email</td>
                                <td>
                                    @{
                                        var oBadge = order.OrderStatus switch
                                        {
                                            "Approved" or "Shipped" => "bg-success",
                                            "Pending" => "bg-warning text-dark",
                                            "Cancelled" => "bg-danger",
                                            "Rejected" => "bg-danger",
                                            "Refunded" => "bg-info text-dark",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @oBadge">@order.OrderStatus</span>
                                </td>
                                <td>
                                    @{
                                        var pBadge = order.PaymentStatus switch
                                        {
                                            "Approved" => "bg-success",
                                            "Pending" => "bg-warning text-dark",
                                            "Rejected" => "bg-danger",
                                            "Refunded" => "bg-info text-dark",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @pBadge">@order.PaymentStatus</span>
                                </td>
                                <td class="text-end">
                                    <strong>₹@order.OrderTotal.ToString("N2")</strong>
                                </td>
                                <td class="text-center">
                                    <a asp-action="Details"
                                       asp-route-orderId="@order.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye-fill"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-dark fw-bold">
                            <td colspan="6" class="text-end py-3">
                                💰 Grand Total :
                            </td>
                            <td class="text-end py-3">
                                <span class="fs-5 text-warning">
                                    ₹@Model.TotalRevenue.ToString("N2")
                                </span>
                            </td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            }
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#monthlyTable').DataTable({
                "order": [[1, "desc"]],
                "pageLength": 10,
                "lengthMenu": [5, 10, 25, 50],
                "columnDefs": [{ orderable: false, targets: 7 }],
                "language": {
                    search: "🔍 Search:",
                    lengthMenu: "Show _MENU_ orders per page",
                    zeroRecords: "No orders found",
                    info: "Showing _START_ to _END_ of _TOTAL_ orders",
                    paginate: { next: "›", previous: "‹" }
                }
            });
        });
    </script>
}