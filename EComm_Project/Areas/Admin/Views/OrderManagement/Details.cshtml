@model EComm_Project_Models.ViewModels.AllOrderVM

@{
    ViewData["Title"] = "Order Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4 px-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-0">
                <i class="bi bi-receipt-cutoff me-2"></i>Order Details
            </h2>
            <p class="text-muted mb-0">Order placed on @Model.OrderHeader.OrderDate.ToString("dddd, MMMM dd yyyy")</p>
        </div>
        <a asp-action="AllOrders" class="btn btn-outline-secondary text-primary">
            <i class="bi bi-arrow-left me-1"></i> Back to Orders
        </a>
    </div>

    <!-- Order ID + Status Banner -->
    <div class="alert mb-4 d-flex justify-content-between align-items-center"
         style="background: linear-gradient(135deg, #0d6efd15, #0d6efd05); border-left: 5px solid #0d6efd;">
        <div>
            <span class="text-muted">Order ID</span>
            <h4 class="fw-bold text-primary mb-0">#@Model.OrderHeader.Id</h4>
        </div>
        <div class="d-flex gap-3">
            <div class="text-center">
                <small class="text-muted d-block">Order Status</small>
                @{
                    var orderBadge = Model.OrderHeader.OrderStatus switch {
                        "Approved" or "Shipped" => "bg-success",
                        "Pending" => "bg-warning text-dark",
                        "Cancelled" => "bg-danger",
                        _ => "bg-info text-dark"
                    };
                }
                <span class="badge @orderBadge fs-6 px-3 py-2">@Model.OrderHeader.OrderStatus</span>
            </div>
            <div class="text-center">
                <small class="text-muted d-block">Payment Status</small>
                @{
                    var payBadge = Model.OrderHeader.PaymentStatus switch {
                        "Approved" => "bg-success",
                        "Pending" => "bg-warning text-dark",
                        "Rejected" => "bg-danger",
                        _ => "bg-secondary"
                    };
                }
                <span class="badge @payBadge fs-6 px-3 py-2">@Model.OrderHeader.PaymentStatus</span>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <!-- LEFT COLUMN -->
        <div class="col-lg-4">

            <!-- Customer Info Card -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0"><i class="bi bi-person-fill me-2"></i>Customer Information</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3"
                             style="width:48px;height:48px;font-size:20px;font-weight:bold;flex-shrink:0;">
                            @Model.OrderHeader.Name?.Substring(0, 1).ToUpper()
                        </div>
                        <div>
                            <div class="fw-bold">@Model.OrderHeader.Name</div>
                            <div class="text-muted small">@Model.OrderHeader.ApplicationUser?.Email</div>
                        </div>
                    </div>
                    <hr class="my-2" />
                    <div class="d-flex align-items-center mt-2">
                        <i class="bi bi-telephone-fill text-primary me-2"></i>
                        <span>@Model.OrderHeader.PhoneNumber</span>
                    </div>
                </div>
            </div>

            <!-- Shipping Address Card -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0"><i class="bi bi-geo-alt-fill me-2"></i>Shipping Address</h6>
                </div>
                <div class="card-body">
                    <address class="mb-0">
                        <strong>@Model.OrderHeader.Name</strong><br />
                        @Model.OrderHeader.StreetAddress<br />
                        @Model.OrderHeader.City, @Model.OrderHeader.State<br />
                        <span class="badge bg-light text-dark border">📮 @Model.OrderHeader.PostalCode</span>
                    </address>
                </div>
            </div>

            <!-- Payment & Tracking Card -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0"><i class="bi bi-truck me-2"></i>Shipping & Payment</h6>
                </div>
                <div class="card-body p-0">
                    <table class="table table-borderless table-sm mb-0">
                        <tr>
                            <td class="text-muted ps-3">Carrier</td>
                            <td class="fw-semibold">@(Model.OrderHeader.Carrier ?? "Not assigned")</td>
                        </tr>
                        <tr>
                            <td class="text-muted ps-3">Tracking No.</td>
                            <td class="fw-semibold">
                                @if (Model.OrderHeader.TrackingNumber != null)
                                {
                                    <span class="badge bg-info text-dark">@Model.OrderHeader.TrackingNumber</span>
                                }
                                else
                                {
                                    <span class="text-muted">Not available</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted ps-3">Ship Date</td>
                            <td class="fw-semibold">
                                @(Model.OrderHeader.ShippingDate == DateTime.MinValue
                                    ? "Not shipped yet"
                                    : Model.OrderHeader.ShippingDate.ToString("MMM dd, yyyy"))
                            </td>
                        </tr>
                        <tr class="table-light">
                            <td class="text-muted ps-3">Transaction ID</td>
                            <td class="fw-semibold small">
                                @if (Model.OrderHeader.TransactionId != null)
                                {
                                    <span class="text-success">✓ @Model.OrderHeader.TransactionId</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

        </div>

        <!-- RIGHT COLUMN — Order Items -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="bi bi-box-seam me-2"></i>Order Items</h6>
                    <span class="badge bg-light text-primary">
                        @Model.OrderDetail.Count() item(s)
                    </span>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Product</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end pe-3">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderDetail)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <div class="d-flex align-items-center gap-3">
                                            @if (item.Product?.ImageUrl != null)
                                            {
                                                <img src="@item.Product.ImageUrl"
                                                     style="width:55px;height:70px;object-fit:cover;border-radius:6px;box-shadow:0 2px 6px rgba(0,0,0,0.15);" />
                                            }
                                            else
                                            {
                                                <div class="bg-light d-flex align-items-center justify-content-center rounded"
                                                     style="width:55px;height:70px;">
                                                    <i class="bi bi-book text-muted fs-4"></i>
                                                </div>
                                            }
                                            <div>
                                                <div class="fw-semibold">@item.Product?.Title</div>
                                                <small class="text-muted">@item.Product?.Author</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center align-middle">
                                        <span class="badge bg-primary rounded-pill">×@item.Count</span>
                                    </td>
                                    <td class="text-end align-middle text-muted">
                                        ₹@item.Price.ToString("N2")
                                    </td>
                                    <td class="text-end align-middle pe-3">
                                        <strong>₹@((item.Price * item.Count).ToString("N2"))</strong>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-light">
                                <td colspan="3" class="text-end fw-bold pe-3 py-3">
                                    <span class="fs-5">Order Total</span>
                                </td>
                                <td class="text-end pe-3 py-3">
                                    <span class="fs-4 fw-bold text-primary">
                                        ₹@Model.OrderHeader.OrderTotal.ToString("N2")
                                    </span>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <!-- Summary Stats -->
            <div class="row g-3 mt-1">
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm text-center p-3"
                         style="border-left: 4px solid #0d6efd !important;">
                        <div class="text-muted small">Total Items</div>
                        <div class="fs-4 fw-bold text-primary">
                            @Model.OrderDetail.Sum(x => x.Count)
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm text-center p-3"
                         style="border-left: 4px solid #198754 !important;">
                        <div class="text-muted small">Order Date</div>
                        <div class="fs-6 fw-bold text-success">
                            @Model.OrderHeader.OrderDate.ToString("MMM dd, yyyy")
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm text-center p-3"
                         style="border-left: 4px solid #dc3545 !important;">
                        <div class="text-muted small">Amount Paid</div>
                        <div class="fs-6 fw-bold text-danger">
                            ₹@Model.OrderHeader.OrderTotal.ToString("N2")
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>