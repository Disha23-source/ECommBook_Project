@model EComm_Project_Models.UserAddress

<form method="post">
    @Html.AntiForgeryToken()

    <div class="border p-3 mt-4">
        <div class="row pb-2 p-2 m-2">
            <h2 class="text-primary"><b>Add New Address</b></h2>
            <hr />
        </div>

        <div class="mb-3">
            <div class="form-group row">
                <div class="col-3">
                    <label asp-for="AddressTitle">Address Title</label>
                </div>
                <div class="col-6">
                    <input asp-for="AddressTitle" class="form-control" placeholder="Home / Work / Hostel / Other" />
                    <span asp-validation-for="AddressTitle" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="mb-3">
            <div class="form-group row">
                <div class="col-3">
                    <label asp-for="StreetAddress">Street Address</label>
                </div>
                <div class="col-6">
                    <input asp-for="StreetAddress" class="form-control" />
                    <span asp-validation-for="StreetAddress" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="mb-3">
            <div class="form-group row">
                <div class="col-3">
                    <label asp-for="City"></label>
                </div>
                <div class="col-6">
                    <input asp-for="City" class="form-control" />
                    <span asp-validation-for="City" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="mb-3">
            <div class="form-group row">
                <div class="col-3">
                    <label asp-for="State"></label>
                </div>
                <div class="col-6">
                    <input asp-for="State" class="form-control" />
                    <span asp-validation-for="State" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="mb-3">
            <div class="form-group row">
                <div class="col-3">
                    <label asp-for="PostalCode"></label>
                </div>
                <div class="col-6">
                    <input asp-for="PostalCode" class="form-control" />
                    <span asp-validation-for="PostalCode" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group row">
            <div class="col-6">
                <button type="submit" class="btn btn-primary form-control">Save Address</button>
            </div>
            <div class="col-6">
                <a asp-area="Customer" asp-controller="Cart" asp-action="Summary" class="btn btn-secondary form-control">
                    Back
                </a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}