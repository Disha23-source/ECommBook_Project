@model EComm_Project_Models.ViewModels.ShoppingCartVM
<form method="post" id="summaryButton">
    <br />
    <div class="backgroundWhiteBorder">
        <div class="container">
            <div class="card">
                <div class="card-header bg-dark text-light ml-0 row container">
                    <div class="col-6">
                        <i class="fa fa-shopping-cart"></i> &nbsp;
                        Shopping Cart
                    </div>
                    <div class="col-6 text-right">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-info btn-sm">Continue Shopping</a>
                    </div>
                </div>
                <div class="card-body">
               
                    @* add checkbox to select all products *@
                    <div class="pb-2">
                        <input type="checkbox" id="selectAll" />
                        <label for="selectAll">Select All Items</label>
                    </div>

                    @foreach (var list in Model.ListCart)
                    {
                        <div class="row align-items-center mb-3">

                            @* Select the item individually *@
                            <div class="col-1">
                                <input type="checkbox" name="selectedItems" value="@list.Id" class="cart-checkbox" data-price="@list.Price" data-count="@list.Count" onchange="updateTotal()" checked />
                            </div>

                            <div class="col-2 text-center py-2">
                                <img src="@list.Product.ImageUrl" class="rounded" width="50%" />
                            </div>

                            <div class="col-6 text-sm-center text-lg-left">
                                <h5><strong>@list.Product.Title</strong></h5>
                                <p><small>@Html.Raw(list.Product.Description)</small></p>
                            </div>

                            <div class="col-3 d-flex justify-content-end align-items-center">
                                <div class="mr-4 text-nowrap">
                                    <h6 class="mb-0">
                                        <strong>
                                            @list.Price <span class="text-muted">x</span> @list.Count = @(list.Price* list.Count)
                                        </strong>
                                    </h6>
                                </div>

                                <div class="d-flex align-items-center">
                                    <a asp-action="minus" asp-route-id="@list.Id" class="btn btn-danger btn-sm mr-2">
                                        <i class="fas fa-minus"></i>
                                    </a>

                                    <a asp-action="plus" asp-route-id="@list.Id" class="btn btn-primary btn-sm mr-2">
                                        <i class="fas fa-plus"></i>
                                    </a>

                                    <a asp-action="delete"
                                       asp-route-id="@list.Id"
                                       class="btn btn-outline-danger btn-sm"
                                       onclick="return valData(event, this)">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </div>

                        </div>
                    }

                    <hr />

                    <div class="row align-items-center mb-2">
                        <div class="col-12 col-md-6 offset-md-6 col-lg-4 offset-lg-8 pr-4">
                            <ul class="list-group">
                                <li class="list-group-item d-flex justify-content-between bg-light">
                                    <span class="text-info"> Total (USD)</span>
                                    <strong class="text-info">$ <span id="txtOrderTotal">@Model.OrderHeader.OrderTotal</span></strong>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <div class="card-footer row">
                        @* Email Confirmation *@
                            @if (!Model.OrderHeader.ApplicationUser.EmailConfirmed)
                            {
                               <div class="col-8 @ViewBag.EmailCSS">
                                   @ViewBag.EmailMessage
                               </div> 
                               <div class="col-4">
                                   <button type="submit" class="btn btn-outline-warning">
                                       Click here to resend Confirmation Email!!!
                                   </button>
                               </div>
                            }
                            else
                            {
                            <div class="col-sm-12 col-lg-4 col-md-6 offset-lg-8 offset-md-6 ">
                                <button type="submit" class="btn btn-success form-control">
                                    Summary
                                </button>
                            </div>
                            }
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
@section Scripts {
    @* JS when we delete the prduct from cart-popup msg *@
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function valData(event, element) {
            event.preventDefault();

            Swal.fire({
                title: 'Remove Item',
                text: "Are you sure you want to remove this item from your cart?",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Remove',
                cancelButtonText: 'Keep'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = element.href;
                }
            });

            return false;
        }
    </script>

        @* Add "Select All" functionality *@
    <script>
        document.getElementById("selectAll").addEventListener("change", function () {
            let checkboxes = document.querySelectorAll(".cart-checkbox");
            checkboxes.forEach(cb => cb.checked = this.checked);
            updateTotal(); // update price also
        });
    </script>
    @* JS to give sweetalert Popup msg when no product is selected *@
    <script>
        document.getElementById("summaryButton").addEventListener("click", function (e) {

            var selectedItems = document.querySelectorAll(".cart-checkbox:checked");

            if (selectedItems.length === 0) {
                e.preventDefault();

                Swal.fire({
                    title: 'No Items Selected!',
                    text: 'Please select at least one product to continue.',
                    icon: 'warning',
                    confirmButtonText: 'OK'
                });
            }
        });
    </script>
        @* When user unchecks one item → Select All should update *@
    <script>
        let selectAll = document.getElementById("selectAll");
        let checkboxes = document.querySelectorAll(".cart-checkbox");

        checkboxes.forEach(cb => {
            cb.addEventListener("change", function () {

                let allChecked = true;

                checkboxes.forEach(c => {
                    if (!c.checked) allChecked = false;
                });

                selectAll.checked = allChecked;
                updateTotal();
            });
        });

        //To Update the Total when we select and unselect the Product
               function updateTotal()
        {
                 let total = 0;
                 document.querySelectorAll('.cart-checkbox:checked').forEach(cb => {
                  const price = parseFloat(cb.getAttribute('data-price'));
                  const count = parseInt(cb.getAttribute('data-count'));
                  total += price * count;
                });
               document.getElementById('txtOrderTotal').innerText = total.toFixed(2);
        }

        document.querySelectorAll('.cart-checkbox').forEach(cb => { cb.addEventListener('change', updateTotal);
        });
             document.getElementById('selectAll').addEventListener('change', function () {
             document.querySelectorAll('.cart-checkbox').forEach(cb => {
             cb.checked = this.checked;
             });
             updateTotal();
             });
    </script>
}